FROM python:3.12-slim

WORKDIR /app

# Copy source first so pip install ".[dev]" can find the app package
COPY pyproject.toml ./
COPY app/ app/
COPY integrations/ integrations/

RUN pip install --no-cache-dir ".[dev]" aiosqlite

COPY tests/ tests/
COPY bots/ bots/
COPY skills/ skills/
COPY migrations/ migrations/
COPY alembic.ini ./

CMD ["pytest", "tests/", "integrations/", "-v"]
