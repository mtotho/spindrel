FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir ".[dev]"

COPY app/ app/
COPY integrations/ integrations/
COPY packages/ packages/
COPY spindrel/ spindrel/
COPY tests/ tests/
COPY skills/ skills/
COPY migrations/ migrations/
COPY docs/ docs/
COPY alembic.ini ./
