{
  "schema_version": "repo-agent-skills.v1",
  "scope": "repo-dev-only",
  "runtime_import": false,
  "notes": "These skills are for development agents working inside this Git repository. They are not Spindrel runtime skills, are not imported into app skill tables, and are not visible to channel bots unless a separate runtime bridge explicitly supplies them. Verification commands run natively in the repo venv; agents must not wrap unit tests in Docker, Dockerfile.test, or docker compose.",
  "skills": [
    {
      "id": "spindrel-backend-operator",
      "path": ".agents/skills/spindrel-backend-operator",
      "description": "Backend source-editing workflow for app services, routers, tools, policies, context, and tests.",
      "triggers": [
        "backend change",
        "api route",
        "service logic",
        "tool implementation",
        "database or migration",
        "pytest"
      ],
      "canonical_guides": [
        "CLAUDE.md",
        "docs/guides/development-process.md",
        "docs/guides/api.md",
        "docs/guides/discovery-and-enrollment.md"
      ],
      "verification_commands": [
        "PYTHONPATH=. pytest tests/unit/test_agent_capabilities.py tests/unit/test_api_access_tools.py -q",
        "git diff --check"
      ]
    },
    {
      "id": "spindrel-ui-operator",
      "path": ".agents/skills/spindrel-ui-operator",
