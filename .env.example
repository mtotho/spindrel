# Spindrel — Self-hosted AI Agent Server
# See docs/setup.md for configuration guide, or run: bash setup.sh

# Auth
API_KEY=your-secret-bearer-key

# Database
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/agentdb

# LLM — run `bash setup.sh` to configure your provider interactively.
# The wizard generates a provider-seed.yaml that seeds a typed DB provider on first boot.
# DEFAULT_MODEL is set by the wizard; override here if needed.
DEFAULT_MODEL=gemma4:e4b

# Legacy fallback — typeless OpenAI-compatible endpoint (used when no DB provider matches).
# Prefer configuring a typed provider via setup wizard or Admin UI > Providers.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=

# Agent
AGENT_MAX_ITERATIONS=15
# LOG_LEVEL=INFO          # INFO = pathway only; DEBUG = full args, token counts, etc.
# AGENT_TRACE=true        # One-line trace per tool/response (no JSON); set for dev debugging
TIMEZONE=America/New_York

# Context compaction
# COMPACTION_MODEL=              # empty = uses bot's model (recommended)
# COMPACTION_INTERVAL=10
# COMPACTION_KEEP_TURNS=2

# STT / Transcription (used when audio_input is "transcribe" or as fallback)
# STT_PROVIDER=local              # "local" (faster-whisper) or future: "groq", "openai"
# WHISPER_MODEL=base.en
# WHISPER_DEVICE=auto              # "auto", "cpu", "cuda"
# WHISPER_COMPUTE_TYPE=auto        # "auto", "int8", "float16", "float32"
# WHISPER_BEAM_SIZE=1
# WHISPER_LANGUAGE=en

# Native audio input — send audio directly to the LLM instead of transcribing first.
# Can be set per-bot in bots/*.yaml (audio_input: native) or per-request via the API.
# Requires an audio-capable model (e.g. Gemini 2.5 Flash) behind LiteLLM.
# The model returns a transcript of what it heard alongside its response.

# RAG / Skills / Tool embeddings.
# Default: local ONNX model via fastembed — no API calls, free, runs on CPU.
# Alternative: use an Ollama embedding model (e.g. nomic-embed-text) or
# an OpenAI-compatible API model (e.g. text-embedding-3-small).
# Local models are zero-padded to EMBEDDING_DIMENSIONS (lossless for cosine similarity).
# If you change models, existing vectors are incompatible — re-embed everything.
# EMBEDDING_DIMENSIONS=1536 is hardcoded in DB migrations — changing it requires a new migration.
# EMBEDDING_MODEL=local/nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

# Optional extra tool directories (colon-separated) scanned at startup in addition to ./tools/
# TOOL_DIRS=/path/to/more/tools

# Optional extra integration directories (colon-separated) scanned at startup in addition to ./integrations/
# Each directory should contain integration folders (e.g. /path/to/my-integrations/mygithub/)
# INTEGRATION_DIRS=/path/to/my-integrations

# Web Search — controls the web_search tool backend (changeable at runtime in Settings UI)
# "searxng" (default): uses a SearXNG instance for search (built-in containers or your own)
# "ddgs": DuckDuckGo + other public engines (lightweight, no containers needed)
# "none": disables web_search — add your own search tool in tools/
# WEB_SEARCH_MODE=searxng
# COMPOSE_PROFILES=web-search   # starts built-in SearXNG + Playwright containers
# SEARXNG_URL=http://searxng:8080          # override to point to your own SearXNG instance
# PLAYWRIGHT_WS_URL=ws://playwright:3000   # override to point to your own Playwright instance

# Planned: Docker sandbox tools (session-scoped containers, shared by bot config) — DOCKER_SANDBOX_PLAN.md

# Dynamic tool selection (cosine similarity over embedded tool descriptions)
# TOOL_RETRIEVAL_THRESHOLD=0.35
# TOOL_RETRIEVAL_TOP_K=10



# Heartbeat schedule control — slow down or disable heartbeats during quiet hours
# HEARTBEAT_QUIET_HOURS=23:00-07:00          # local time window (HH:MM-HH:MM); empty = no quiet hours
# HEARTBEAT_QUIET_INTERVAL_MINUTES=60        # interval during quiet hours (0 = disabled entirely)
# HEARTBEAT_ACTIVE_INTERVAL_MINUTES=5        # default active interval (per-heartbeat DB value takes precedence)

# API rate limiting — limits requests to the Spindrel server itself (NOT LLM provider calls).
# Protects against runaway clients hammering your server. In-memory token bucket per API key/IP.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=100/minute        # all Spindrel API endpoints
# RATE_LIMIT_CHAT=30/minute            # /chat and /chat/stream (stricter)

# Webhooks — manage via Admin UI > Developer > Webhooks
# (supports per-endpoint event filtering, HMAC signing, and delivery tracking)

# Public base URL (used by integration settings page to show copyable webhook URLs)
# Set this to your tunnel/reverse-proxy URL if your server is behind NAT.
# See integrations/github/README.md for Cloudflare Tunnel setup.
# BASE_URL=https://agent.yourdomain.com

# Integration env vars (Slack, Frigate, etc.) — configure via Admin UI > Integrations,
# or set here for deploy-time config. Each integration's setup.py declares its vars.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# AGENT_API_KEY=...                 # same as API_KEY; used by Slack bot to call the server
# AGENT_BASE_URL=http://localhost:8000

# Android client (baked into the app at build time via app.config.js)
# ANDROID_AGENT_URL=http://192.168.1.100:8000   # server URL for the Android client (use your LAN IP)
# PICOVOICE_ACCESS_KEY=your-picovoice-key        # free from console.picovoice.ai (wake word + optional local Cheetah STT)

# Weather tool (if using tools/weather.py)
# OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Path translation for Docker deployment (when server runs in Docker).
# WORKSPACE_HOST_DIR is the host-side path for child container -v mounts.
# WORKSPACE_LOCAL_DIR is the mount point inside the server container.
# Leave both empty when running the server on the host (dev mode).
# WORKSPACE_HOST_DIR=/home/you/.agent-workspaces
# WORKSPACE_LOCAL_DIR=/workspace-data

DOCKER_SANDBOX_ENABLED=false
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_SANDBOX_MAX_CONCURRENT=10
DOCKER_SANDBOX_DEFAULT_TIMEOUT=30
DOCKER_SANDBOX_MAX_OUTPUT_BYTES=65536
# Comma-separated paths; or bracketed list — JSON ["..."] / Python ['...'] / unquoted [/path/to/dir]
# DOCKER_SANDBOX_MOUNT_ALLOWLIST=/home/you/workspace,/data/shared
DOCKER_SANDBOX_MOUNT_ALLOWLIST=
DOCKER_SANDBOX_IDLE_PRUNE_INTERVAL=300
