FROM python:3.12-slim

# Node.js + claude CLI — lets the agent run `claude --print "..."` inside sandbox containers
# via exec_sandbox. Also installs git for repo operations.
# Auth: set ANTHROPIC_API_KEY in the sandbox profile env (admin UI) or mount ~/.claude.
RUN apt-get update -qq && apt-get install -y -qq git gh nodejs npm && \
    npm install -g @anthropic-ai/claude-code && \
    rm -rf /var/lib/apt/lists/*

ENV GIT_TERMINAL_PROMPT=0

COPY dockerfiles/git-credential-github-env.sh /usr/local/bin/git-credential-github-env
RUN chmod +x /usr/local/bin/git-credential-github-env

# GITHUB_TOKEN must be set when the container runs (sandbox profile env). Not required at docker build.
RUN git config --global credential.helper /usr/local/bin/git-credential-github-env && \
    git config --global user.email "agent@spindrel.dev" && \
    git config --global user.name "Spindrel Agent" && \
    git config --global --add safe.directory /workspace

RUN useradd -m -u 1000 agent && \
    mkdir -p /workspace && \
    chown -R agent:agent /workspace

WORKDIR /workspace
