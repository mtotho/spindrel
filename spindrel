#!/usr/bin/env bash
set -euo pipefail

# ── Spindrel CLI ─────────────────────────────────────────────────────────────
# Thin shell dispatcher for managing the Spindrel agent server.
# Commands: start, stop, restart, pull, pull-integrations, backup, restore, status, logs

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="${REPO_DIR}/docker-compose.yml"
SERVICE_NAME="spindrel"
BACKING_SERVICES="postgres searxng playwright"

# Load API_KEY and BASE_URL from .env for API calls
_load_env() {
    local _api_key="" _base_url=""
    if [ -f "$REPO_DIR/.env" ]; then
        _api_key="$(grep -E '^API_KEY=' "$REPO_DIR/.env" | cut -d= -f2- | tr -d '"' | tr -d "'" || true)"
        _base_url="$(grep -E '^BASE_URL=' "$REPO_DIR/.env" | cut -d= -f2- | tr -d '"' | tr -d "'" || true)"
    fi
    SPINDREL_API_KEY="${_api_key}"
    SPINDREL_URL="${_base_url:-http://localhost:8000}"
}

# ── Helpers ──────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
Usage: spindrel <command> [options]

Commands:
  start              Start backing services and the Spindrel app
  stop               Stop the Spindrel app and backing services
  restart            Restart the Spindrel app (and optionally backing services)
  pull               Git pull + reinstall deps + restart
  pull-integrations  Git pull external integration repos + restart
  backup             Run database backup
  restore            Restore database from backup
  status             Show status of all services
  logs               Tail application or service logs

Run 'spindrel <command> --help' for details on a specific command.
EOF
}

die() {
    echo "error: $*" >&2
    exit 1
}

compose() {
    docker compose -f "$COMPOSE_FILE" "$@"
}

wait_for_postgres() {
    echo "Waiting for postgres to be healthy..."
    local retries=30
    while [ $retries -gt 0 ]; do
        if compose exec -T postgres pg_isready -U agent -d agentdb >/dev/null 2>&1; then
            echo "Postgres is ready."
            return 0
        fi
        retries=$((retries - 1))
        sleep 1
    done
    die "Postgres failed to become healthy"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel start

Start Docker backing services (postgres, searxng, playwright),
wait for postgres health check, then start the Spindrel app via systemd.
EOF
        return 0
    fi

    echo "Starting backing services..."
    compose up -d $BACKING_SERVICES
    wait_for_postgres

    echo "Starting Spindrel app service..."
    sudo systemctl start "$SERVICE_NAME"
    echo "Spindrel started."
}

cmd_stop() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel stop

Stop the Spindrel app service, then stop Docker backing services.
EOF
        return 0
    fi

    echo "Stopping Spindrel app service..."
    sudo systemctl stop "$SERVICE_NAME" 2>/dev/null || true

    echo "Stopping backing services..."
    compose down
    echo "Spindrel stopped."
}

cmd_restart() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel restart

Restart the Spindrel app service. Backing services are not restarted
unless they are not running.
EOF
        return 0
    fi

    # Ensure backing services are up
    compose up -d $BACKING_SERVICES
    wait_for_postgres

    echo "Restarting Spindrel app service..."
    sudo systemctl restart "$SERVICE_NAME"
    echo "Spindrel restarted."
}

cmd_pull() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel pull

Git pull latest changes, reinstall Python dependencies, run database
migrations, and restart the Spindrel app.
EOF
        return 0
    fi

    echo "Pulling latest changes..."
    git -C "$REPO_DIR" pull --rebase origin master

    echo "Installing dependencies..."
    pip install -e "$REPO_DIR" >/dev/null

    echo "Running migrations..."
    compose up -d postgres
    wait_for_postgres
    alembic -c "$REPO_DIR/alembic.ini" upgrade head

    echo "Restarting Spindrel..."
    sudo systemctl restart "$SERVICE_NAME"
    echo "Pull complete."
}

cmd_pull_integrations() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel pull-integrations

Git pull each external integration directory (from INTEGRATION_DIRS in .env
or the DB), including any nested git repos, then restart the app so updated
tools/skills/capabilities are loaded.
EOF
        return 0
    fi

    # Read INTEGRATION_DIRS from the running server (has DB overrides applied)
    _load_env
    local dirs=""
    if [ -n "$SPINDREL_API_KEY" ]; then
        dirs="$(curl -sf -H "Authorization: Bearer $SPINDREL_API_KEY" \
            "${SPINDREL_URL}/api/v1/admin/settings" 2>/dev/null \
            | python3 -c "
import sys, json
data = json.load(sys.stdin)
for group in data.get('groups', {}).values():
    for s in group:
        if s['key'] == 'INTEGRATION_DIRS':
            print(s.get('value') or '')
            sys.exit(0)
" 2>/dev/null || true)"
    fi

    # Fall back to .env if server isn't reachable
    if [ -z "$dirs" ] && [ -f "$REPO_DIR/.env" ]; then
        dirs="$(grep -E '^INTEGRATION_DIRS=' "$REPO_DIR/.env" | cut -d= -f2- | tr -d '"' | tr -d "'")"
    fi

    if [ -z "$dirs" ]; then
        die "No INTEGRATION_DIRS configured"
    fi
    echo "INTEGRATION_DIRS: $dirs"

    local pulled=0

    # Split on : and process each path
    IFS=':' read -ra PATHS <<< "$dirs"
    for raw_path in "${PATHS[@]}"; do
        # Expand ~ to home dir
        local dir_path="${raw_path/#\~/$HOME}"
        dir_path="$(realpath "$dir_path" 2>/dev/null || echo "$dir_path")"

        if [ ! -d "$dir_path" ]; then
            echo "  skip: $dir_path (not found)"
            continue
        fi

        # Pull the top-level dir if it's a git repo
        if [ -d "$dir_path/.git" ]; then
            echo "  pulling: $dir_path"
            git -C "$dir_path" pull --rebase || echo "  warning: pull failed for $dir_path"
            pulled=$((pulled + 1))
        fi

        # Pull any nested git repos (one level deep)
        for sub in "$dir_path"/*/; do
            [ -d "$sub/.git" ] || continue
            echo "  pulling: $sub"
            git -C "$sub" pull --rebase || echo "  warning: pull failed for $sub"
            pulled=$((pulled + 1))
        done
    done

    if [ $pulled -eq 0 ]; then
        echo "No git repos found in INTEGRATION_DIRS."
        return 0
    fi

    echo "Pulled $pulled repo(s). Restarting Spindrel..."
    sudo systemctl restart "$SERVICE_NAME"
    echo "Done."
}

cmd_backup() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel backup

Run the database backup script (scripts/backup.sh).
Creates a compressed archive and uploads to the configured S3 remote.
EOF
        return 0
    fi

    exec "$REPO_DIR/scripts/backup.sh"
}

cmd_restore() {
    local archive=""
    local yes_flag=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --help)
                cat <<EOF
Usage: spindrel restore [archive] [--yes]

Restore database from a backup archive. If no archive is specified,
the latest backup is pulled from the S3 remote.

Options:
  --yes    Skip confirmation prompt
EOF
                return 0
                ;;
            --yes|-y)
                yes_flag=true
                shift
                ;;
            *)
                archive="$1"
                shift
                ;;
        esac
    done

    local args=()
    if [ -n "$archive" ]; then
        args+=("$archive")
    fi
    if [ "$yes_flag" = true ]; then
        args+=("--yes")
    fi

    exec "$REPO_DIR/scripts/restore.sh" "${args[@]}"
}

cmd_status() {
    if [ "${1:-}" = "--help" ]; then
        cat <<EOF
Usage: spindrel status

Show the status of the Spindrel app service and all backing services.
EOF
        return 0
    fi

    echo "Spindrel Status"
    echo "─────────────────────────────"

    # App service
    if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
        local since
        since=$(systemctl show "$SERVICE_NAME" --property=ActiveEnterTimestamp --value 2>/dev/null || echo "unknown")
        echo "App service:    ● active (running) since ${since}"
    else
        echo "App service:    ○ inactive"
    fi

    # Backing services
    for svc in postgres searxng playwright; do
        local state
        state=$(compose ps --format '{{.State}}' "$svc" 2>/dev/null || echo "not found")
        if [ "$state" = "running" ]; then
            echo "${svc}:$(printf '%*s' $((16 - ${#svc})) '')● ${state}"
        else
            echo "${svc}:$(printf '%*s' $((16 - ${#svc})) '')○ ${state}"
        fi
    done
}

cmd_logs() {
    local follow=false
    local service=""
    local lines=50

    while [ $# -gt 0 ]; do
        case "$1" in
            --help)
                cat <<EOF
Usage: spindrel logs [--follow] [--service NAME] [--lines N]

Tail logs for the Spindrel app or a specific backing service.

Options:
  -f, --follow           Stream logs continuously
  -s, --service NAME     Show logs for a backing service (postgres, searxng, playwright)
  -n, --lines N          Number of lines to show (default: 50)
EOF
                return 0
                ;;
            -f|--follow)
                follow=true
                shift
                ;;
            -s|--service)
                service="$2"
                shift 2
                ;;
            -n|--lines)
                lines="$2"
                shift 2
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done

    if [ -n "$service" ]; then
        # Docker compose logs for backing service
        local args=("--tail" "$lines")
        if [ "$follow" = true ]; then
            args+=("-f")
        fi
        compose logs "${args[@]}" "$service"
    else
        # Journalctl for the app service
        local args=("-u" "$SERVICE_NAME" "-n" "$lines" "--no-pager")
        if [ "$follow" = true ]; then
            args+=("-f")
        fi
        journalctl "${args[@]}"
    fi
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
    usage
    exit 0
fi

command="$1"
shift

case "$command" in
    start)   cmd_start "$@" ;;
    stop)    cmd_stop "$@" ;;
    restart) cmd_restart "$@" ;;
    pull)    cmd_pull "$@" ;;
    pull-integrations) cmd_pull_integrations "$@" ;;
    backup)  cmd_backup "$@" ;;
    restore) cmd_restore "$@" ;;
    status)  cmd_status "$@" ;;
    logs)    cmd_logs "$@" ;;
    --help|-h|help)
        usage
        ;;
    *)
        die "Unknown command: $command. Run 'spindrel --help' for usage."
        ;;
esac
