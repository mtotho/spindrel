#!/usr/bin/env python3
"""Spindrel CLI — single entry point for service management.

Auto-detects deployment mode:
  - Docker: uses docker compose commands
  - Systemd (host): uses systemctl commands

Install: ln -sf /path/to/scripts/spindrel /usr/local/bin/spindrel
"""

import argparse
import os
import subprocess
import sys

def _discover_systemd_services():
    """Discover installed spindrel systemd services dynamically."""
    services = []
    systemd_dir = "/etc/systemd/system"
    if os.path.isdir(systemd_dir):
        for f in sorted(os.listdir(systemd_dir)):
            if f.startswith("spindrel") and f.endswith(".service"):
                services.append(f.removesuffix(".service"))
    return services or ["spindrel"]  # fallback to main service


def get_repo_dir():
    """Auto-detect repo directory from script location, cwd, or env var."""
    for var in ("SPINDREL_HOME", "SPINDREL_REPO_PATH"):
        path = os.environ.get(var)
        if path and os.path.isdir(os.path.join(path, ".git")):
            return path

    # Script location (works when installed via symlink — resolves to real path)
    script_dir = os.path.dirname(os.path.realpath(__file__))
    repo_dir = os.path.dirname(script_dir)
    if os.path.isdir(os.path.join(repo_dir, ".git")):
        return repo_dir

    cwd = os.getcwd()
    if os.path.isdir(os.path.join(cwd, ".git")):
        return cwd

    print("error: Could not find repo directory. Set SPINDREL_HOME or run from the repo.", file=sys.stderr)
    sys.exit(1)


def is_docker_mode(repo):
    """Detect if running in Docker mode (docker-compose.yml exists and no systemd services)."""
    has_compose = os.path.isfile(os.path.join(repo, "docker-compose.yml"))
    has_systemd = os.path.isfile("/etc/systemd/system/spindrel.service")
    # If both exist, prefer systemd (explicit install-service.sh was run)
    if has_systemd:
        return False
    return has_compose


def run(cmd, check=True, shell=True, **kwargs):
    """Run a command, printing it first."""
    print(f"  → {cmd}")
    result = subprocess.run(cmd, shell=shell, **kwargs)
    if check and result.returncode != 0:
        print(f"  ✗ Command failed (exit {result.returncode})", file=sys.stderr)
    return result


def dc(repo, *args):
    """Run a docker compose command in the repo directory."""
    cmd = f"docker compose -f {repo}/docker-compose.yml {' '.join(args)}"
    return run(cmd)


# ── Docker mode commands ─────────────────────────────────────────────────────

def docker_start(repo, args):
    print("Starting containers...")
    dc(repo, "up -d")


def docker_stop(repo, args):
    print("Stopping containers...")
    dc(repo, "down")


def docker_restart(repo, args):
    svc = getattr(args, "service", None)
    if svc:
        print(f"Restarting {svc}...")
        dc(repo, f"restart {svc}")
    else:
        print("Restarting all containers...")
        dc(repo, "restart")


def docker_pull(repo, args):
    print(f"Pulling latest in {repo}...")
    result = run(f"git -C {repo} fetch origin && git -C {repo} pull --rebase origin master")
    if result.returncode != 0:
        print("Pull failed — skipping rebuild.", file=sys.stderr)
        return
    print("Rebuilding containers...")
    dc(repo, "build")
    dc(repo, "up -d")


def docker_status(repo, args):
    dc(repo, "ps")


def docker_logs(repo, args):
    svc = getattr(args, "service", None)
    tail = getattr(args, "lines", 50)
    follow = "-f" if not getattr(args, "no_follow", False) else ""
    target = svc or ""
    print(f"Tailing logs ({svc or 'all services'})... (Ctrl+C to stop)")
    try:
        dc(repo, f"logs --tail {tail} {follow} {target}")
    except KeyboardInterrupt:
        pass


def docker_rebuild(repo, args):
    print("Rebuilding and restarting...")
    dc(repo, "build")
    dc(repo, "up -d")


def docker_backup(repo, args):
    script = os.path.join(repo, "scripts", "backup.sh")
    if not os.path.isfile(script):
        print(f"error: {script} not found", file=sys.stderr)
        sys.exit(1)
    run(f"bash {script}", check=False)


def docker_restore(repo, args):
    script = os.path.join(repo, "scripts", "restore.sh")
    if not os.path.isfile(script):
        print(f"error: {script} not found", file=sys.stderr)
        sys.exit(1)
    cmd = f"bash {script}"
    if args.backup_file:
        cmd += f" {args.backup_file}"
    run(cmd)


# ── Systemd mode commands ────────────────────────────────────────────────────

def _daemon_reload():
    run("sudo systemctl daemon-reload")


def systemd_start(repo, args):
    _daemon_reload()
    print("Starting services...")
    for svc in _discover_systemd_services():
        run(f"sudo systemctl start {svc}.service")


def systemd_stop(repo, args):
    print("Stopping services...")
    for svc in reversed(_discover_systemd_services()):
        run(f"sudo systemctl stop {svc}.service")


def systemd_restart(repo, args):
    _daemon_reload()
    print("Restarting services...")
    for svc in _discover_systemd_services():
        run(f"sudo systemctl restart {svc}.service")


def _build_workspace_image(repo):
    dockerfile = os.path.join(repo, "Dockerfile.workspace")
    if not os.path.isfile(dockerfile):
        return
    print("Building workspace image...")
    run(f"docker build -t agent-workspace:latest -f {dockerfile} {repo}")


def _rebuild_ui(repo):
    dockerfile = os.path.join(repo, "ui", "Dockerfile")
    if not os.path.isfile(dockerfile):
        return
    print("Rebuilding UI...")
    result = run(f"docker compose -f {repo}/docker-compose.yml build ui")
    if result.returncode != 0:
        print("warning: UI build failed.", file=sys.stderr)
        return
    run(f"docker compose -f {repo}/docker-compose.yml up -d ui")


def _build_integration_uis(repo):
    integrations_dir = os.path.join(repo, "integrations")
    if not os.path.isdir(integrations_dir):
        return
    for name in sorted(os.listdir(integrations_dir)):
        dashboard_dir = os.path.join(integrations_dir, name, "dashboard")
        pkg_json = os.path.join(dashboard_dir, "package.json")
        if not os.path.isfile(pkg_json):
            continue
        print(f"Building integration UI: {name}...")
        result = run(f"cd {dashboard_dir} && npm ci --ignore-scripts && npx vite build", check=False)
        if result.returncode != 0:
            print(f"warning: Integration UI build failed for {name}.", file=sys.stderr)


def systemd_pull(repo, args):
    print(f"Pulling latest in {repo}...")
    result = run(f"git -C {repo} fetch origin && git -C {repo} pull --rebase origin master")
    if result.returncode != 0:
        print("Pull failed — skipping restart.", file=sys.stderr)
        return
    _build_workspace_image(repo)
    _build_integration_uis(repo)
    _rebuild_ui(repo)
    systemd_restart(repo, args)


def systemd_status(repo, args):
    print("=== Systemd Services ===")
    for svc in _discover_systemd_services():
        run(f"systemctl status {svc}.service --no-pager -l", check=False)
        print()
    print("=== Docker Containers ===")
    run("docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'", check=False)
    print()
    print("=== Disk Usage ===")
    run("df -h / | tail -1", check=False)
    run("docker system df 2>/dev/null", check=False)


def systemd_logs(repo, args):
    svc = getattr(args, "service", None)
    services = _discover_systemd_services()
    if svc and svc not in services:
        print(f"error: Unknown service '{svc}'. Choose from: {', '.join(services)}", file=sys.stderr)
        sys.exit(1)
    units = [f"-u {svc}"] if svc else [f"-u {s}" for s in services]
    cmd = f"journalctl {' '.join(units)} -f --no-pager -n 50"
    print(f"Tailing logs ({svc or 'all services'})... (Ctrl+C to stop)")
    try:
        run(cmd)
    except KeyboardInterrupt:
        pass


def _load_env(repo):
    """Read API_KEY and BASE_URL from .env."""
    env_file = os.path.join(repo, ".env")
    api_key = ""
    base_url = "http://localhost:8000"
    if os.path.isfile(env_file):
        with open(env_file) as f:
            for line in f:
                line = line.strip()
                if line.startswith("API_KEY="):
                    api_key = line.split("=", 1)[1].strip("\"'")
                elif line.startswith("BASE_URL="):
                    val = line.split("=", 1)[1].strip("\"'")
                    if val:
                        base_url = val
    return api_key, base_url


def _get_integration_dirs(repo):
    """Get INTEGRATION_DIRS from the running server API, fall back to .env."""
    import json
    import urllib.request

    api_key, base_url = _load_env(repo)

    # Try the server API first (has DB overrides applied)
    if api_key:
        try:
            req = urllib.request.Request(
                f"{base_url}/api/v1/admin/settings",
                headers={"Authorization": f"Bearer {api_key}"},
            )
            with urllib.request.urlopen(req, timeout=5) as resp:
                data = json.loads(resp.read())
                for group in data.get("groups", {}).values():
                    for s in group:
                        if s["key"] == "INTEGRATION_DIRS" and s.get("value"):
                            return s["value"]
        except Exception:
            pass

    # Fall back to .env
    env_file = os.path.join(repo, ".env")
    if os.path.isfile(env_file):
        with open(env_file) as f:
            for line in f:
                if line.strip().startswith("INTEGRATION_DIRS="):
                    return line.strip().split("=", 1)[1].strip("\"'")
    return ""


def _pull_integrations(repo, args):
    dirs = _get_integration_dirs(repo)
    if not dirs:
        print("error: No INTEGRATION_DIRS configured", file=sys.stderr)
        sys.exit(1)

    print(f"INTEGRATION_DIRS: {dirs}")
    pulled = 0

    for raw_path in dirs.split(":"):
        raw_path = raw_path.strip()
        if not raw_path:
            continue
        dir_path = os.path.expanduser(raw_path)
        dir_path = os.path.realpath(dir_path)

        if not os.path.isdir(dir_path):
            print(f"  skip: {dir_path} (not found)")
            continue

        # Pull top-level if it's a git repo
        if os.path.isdir(os.path.join(dir_path, ".git")):
            print(f"  pulling: {dir_path}")
            run(f"git -C {dir_path} pull --rebase", check=False)
            pulled += 1

        # Pull nested git repos (one level deep)
        for entry in sorted(os.listdir(dir_path)):
            sub = os.path.join(dir_path, entry)
            if os.path.isdir(sub) and os.path.isdir(os.path.join(sub, ".git")):
                print(f"  pulling: {sub}")
                run(f"git -C {sub} pull --rebase", check=False)
                pulled += 1

    if pulled == 0:
        print("No git repos found in INTEGRATION_DIRS.")
        return

    print(f"Pulled {pulled} repo(s). Restarting Spindrel...")


def systemd_pull_integrations(repo, args):
    _pull_integrations(repo, args)
    systemd_restart(repo, args)


def docker_pull_integrations(repo, args):
    _pull_integrations(repo, args)
    docker_restart(repo, args)


def systemd_backup(repo, args):
    docker_backup(repo, args)  # same implementation


def systemd_restore(repo, args):
    docker_restore(repo, args)  # same implementation


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="spindrel",
        description="Spindrel service management CLI",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("start", help="Start services")
    sub.add_parser("stop", help="Stop services")

    restart_p = sub.add_parser("restart", help="Restart services")
    restart_p.add_argument("service", nargs="?", default=None,
                           help="Specific service to restart (Docker mode)")

    sub.add_parser("pull", help="Git pull + rebuild + restart")
    sub.add_parser("pull-integrations", help="Git pull external integration repos + restart")
    sub.add_parser("rebuild", help="Rebuild containers and restart (Docker mode)")
    sub.add_parser("backup", help="Run backup")
    sub.add_parser("status", help="Show service status")

    restore_p = sub.add_parser("restore", help="Restore from backup")
    restore_p.add_argument("backup_file", nargs="?", default=None,
                           help="Path to backup archive")

    logs_p = sub.add_parser("logs", help="Tail service logs")
    logs_p.add_argument("service", nargs="?", default=None,
                        help="Service name to filter")
    logs_p.add_argument("-n", "--lines", type=int, default=50,
                        help="Number of lines to show (default: 50)")
    logs_p.add_argument("--no-follow", action="store_true",
                        help="Don't follow (print and exit)")

    args = parser.parse_args()
    repo = get_repo_dir()
    docker = is_docker_mode(repo)

    if docker:
        mode_label = "Docker"
        commands = {
            "start": docker_start,
            "stop": docker_stop,
            "restart": docker_restart,
            "pull": docker_pull,
            "pull-integrations": docker_pull_integrations,
            "rebuild": docker_rebuild,
            "status": docker_status,
            "logs": docker_logs,
            "backup": docker_backup,
            "restore": docker_restore,
        }
    else:
        mode_label = "Systemd"
        commands = {
            "start": systemd_start,
            "stop": systemd_stop,
            "restart": systemd_restart,
            "pull": systemd_pull,
            "pull-integrations": systemd_pull_integrations,
            "rebuild": lambda r, a: print("Rebuild is only for Docker mode. Use 'spindrel pull' instead."),
            "status": systemd_status,
            "logs": systemd_logs,
            "backup": systemd_backup,
            "restore": systemd_restore,
        }

    print(f"  [{mode_label} mode]")
    commands[args.command](repo, args)


if __name__ == "__main__":
    main()
