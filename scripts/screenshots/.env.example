# e2e instance API base (NOT production)
SPINDREL_URL=http://10.10.30.208:18000

# e2e instance UI base (Vite dev server / built UI)
SPINDREL_UI_URL=http://10.10.30.208:18081

# Admin-scoped API key on the e2e instance.
# Per Test Server Operations notes, the default seeded key is:
# e2e-dedicated-instance-key-2026
SPINDREL_API_KEY=e2e-dedicated-instance-key-2026

# Admin user creds on the e2e instance, used to mint JWT tokens for the
# browser's localStorage (Zustand persist key "agent-auth").
SPINDREL_LOGIN_EMAIL=
SPINDREL_LOGIN_PASSWORD=

# SSH alias used by stage/_exec.py for the narrow docker-exec escape hatch
# (mid-run pipeline step_states, usage_events seeding). Only two fields
# cross this hatch; everything else stays on the HTTP API.
SSH_ALIAS=spindrel-bot

# Docker container name running the e2e agent-server process. The _exec
# helpers `docker exec` into this to run short SQLAlchemy scripts.
SSH_CONTAINER=spindrel-e2e-agent-server-1

# Screenshot output roots (relative to the repo root). Defaults match the
# Track - Docs Refresh Phase A punch list.
DOCS_IMAGES_DIR=docs/images
WEBSITE_IMAGES_DIR=../spindrel-website/public/images/screenshots
