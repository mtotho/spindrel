{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "outDir": "./.chat-test-dist",
    "types": ["node"]
  },
  "include": [
    "app/(app)/channels/[channelId]/chatUtils.ts",
    "app/(app)/channels/[channelId]/chatUtils.test.ts",
    "src/types/api.ts",
    "src/stores/chat.ts",
    "src/stores/chat.test.ts",
    "src/stores/ui.ts",
    "src/lib/paletteRoutes.ts",
    "src/lib/paletteRoutes.test.ts",
    "src/lib/channelPanelLayout.ts",
    "src/lib/channelPanelLayout.test.ts",
    "src/lib/recentPages.ts",
    "src/components/chat/slashCommandRequest.ts",
    "src/components/chat/slashCommandRequest.test.ts",
    "src/components/chat/sessionMessageSync.ts",
    "src/components/chat/sessionMessageSync.test.ts",
    "src/components/chat/messageJsonCopy.ts",
    "src/components/chat/messageJsonCopy.test.ts",
    "src/components/chat/chatModes.ts",
    "src/components/chat/resultViewRegistry.tsx",
    "src/components/chat/resultViewRegistry.test.ts",
    "src/components/chat/toolTranscriptModel.ts",
    "src/components/chat/toolTranscriptModel.test.ts",
    "src/components/chat/renderArchitecture.test.ts",
    "src/components/chat/renderers/widgetTheme.ts",
    "src/components/chat/renderers/widgetTheme.test.ts",
    "src/components/palette/types.ts",
    "src/components/palette/catalog.ts",
    "src/components/palette/items.test.ts",
    "src/components/palette/route-meta.ts",
    "src/components/palette/recent.ts",
    "src/components/palette/recent.test.ts"
  ]
}
